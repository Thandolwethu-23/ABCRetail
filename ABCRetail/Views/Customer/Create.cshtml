<h2>Create Customer</h2>

<form method="post">
    <label>Name:</label>
    <input type="text" name="name" required />

    <br /><br />

    <label>Email:</label>
    <input type="email" name="email" required />

    <br /><br />

    <button type="submit">Save</button>
</form>

<p>@ViewBag.Message</p>